{
  "name": "@hunter-lab/bottom-sheet",
  "version": "0.0.3",
  "description": "A beautifully simple, lightweight, and customizable Bottom Sheet for React Native.",
  "repository": "https://github.com/dqtkien/bottom-sheet",
  "author": "Hunter Lab",
  "license": "MIT",
  "keywords": [
    "hunter-lab",
    "react-native",
    "bottom-sheet",
    "bottomsheet",
    "modal",
    "ui",
    "no-dependencies",
    "typescript"
  ],
  "main": "lib/commonjs/index.js",
  "react-native": "src/index.tsx",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "types": "./lib/typescript/index.d.ts"
    }
  },
  "source": "src/index.tsx",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "prepack": "npm run build",
    "release": "rm -rf lib && npm run build && npm publish --access public"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.8",
    "react-native-builder-bob": "^0.30.0",
    "typescript": "^5.0.0"
  },
  "resolutions": {
    "@types/react": "^18.2.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
